{
  "name": "@matric/eval-client",
  "version": "0.1.0",
  "description": "TypeScript client for matric-eval evaluation framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/test/*.test.js"
  },
  "keywords": [
    "matric",
    "eval",
    "llm",
    "benchmark",
    "ollama"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "publishConfig": {
    "registry": "https://git.integrolabs.net/api/packages/roctinam/npm/"
  },
  "repository": {
    "type": "git",
    "url": "https://git.integrolabs.net/roctinam/matric-eval.git",
    "directory": "bindings/typescript"
  }
}
